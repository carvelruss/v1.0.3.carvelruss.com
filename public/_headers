# Never cache the HTML entry point so browsers always get the latest chunk manifest
/index.html
  Cache-Control: no-cache, no-store, must-revalidate

# Also covers the root path (Cloudflare Pages serves index.html here too)
/
  Cache-Control: no-cache, no-store, must-revalidate

# Long-cache immutable assets (Vite content-hashes them, so safe to cache forever)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
